<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_nature">

    <!-- Вуаль -->
    <View
        android:id="@+id/viewOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E612141D" />

    <!-- КНОПКА ЗАКРЫТЬ (РОВНО ТАМ ЖЕ, ГДЕ БЫЛА КНОПКА МЕНЮ) -->
    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="50dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_back"
        android:padding="10dp"
        android:scaleType="fitCenter"
        app:tint="#FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Заголовок -->
    <TextView
        android:id="@+id/tvMenuTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Menu"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Контент -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="30dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvMenuTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="40dp">

            <!-- 1. ПРОФИЛЬ (ТЕМНОЕ СТЕКЛО) -->
            <!-- 1. ПРОФИЛЬ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_item"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <!-- ФОН АВАТАРА (Это просто View) -->
                <View
                    android:id="@+id/vAvatar"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_glass_button"
                    android:backgroundTint="#FFD54F"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <!-- ИКОНКА (Добавили ID: ivAvatarIcon) -->
                <ImageView
                    android:id="@+id/ivAvatarIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_profile"
                    app:tint="#FFFFFF"
                    app:layout_constraintStart_toStartOf="@id/vAvatar"
                    app:layout_constraintEnd_toEndOf="@id/vAvatar"
                    app:layout_constraintTop_toTopOf="@id/vAvatar"
                    app:layout_constraintBottom_toBottomOf="@id/vAvatar"/>

                <!-- ... Остальной текст без изменений ... -->

                <!-- Заголовок (Имя пользователя) -->
                <TextView
                    android:id="@+id/tvUserTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Guest User"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/vAvatar"
                    app:layout_constraintTop_toTopOf="@id/vAvatar"
                    app:layout_constraintBottom_toTopOf="@+id/tvUserSub"
                    app:layout_constraintVertical_chainStyle="packed" />

                <!-- Подзаголовок (Статус/Призыв) -->
                <!-- ДОБАВЛЕН ID: tvUserSub -->
                <TextView
                    android:id="@+id/tvUserSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Tap to Log In"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    app:layout_constraintStart_toEndOf="@id/vAvatar"
                    app:layout_constraintTop_toBottomOf="@id/tvUserTitle"
                    app:layout_constraintBottom_toBottomOf="@id/vAvatar" />

                <!-- Бейдж (FREE/PRO) -->
                <!-- ДОБАВЛЕН ID: tvBadge -->
                <TextView
                    android:id="@+id/tvBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge"
                    android:text="FREE"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- PREMIUM БАННЕР (ИСКУССТВЕННОЕ ДЫХАНИЕ) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnPremium"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_premium_modern"
                android:clickable="true"
                android:focusable="true">

                <!-- Иконка (Ракета) -->
                <ImageView
                    android:id="@+id/ivPremIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="20dp"
                    android:src="@drawable/ic_rocket"
                    app:tint="#FFFFFF"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Заголовок -->
                <!-- Привязан: Снизу к подзаголовку, Сверху к иконке -->
                <TextView
                    android:id="@+id/tvPremTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Upgrade to PRO"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@+id/tvPremSub"
                    app:layout_constraintStart_toEndOf="@id/ivPremIcon"
                    app:layout_constraintTop_toTopOf="@id/ivPremIcon"
                    app:layout_constraintVertical_chainStyle="packed" />

                <!-- Подзаголовок -->
                <!-- Привязан: Сверху к заголовку, Снизу к иконке -->
                <TextView
                    android:id="@+id/tvPremSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Remove ads &amp; unlock speed"
                    android:textColor="#E0FFFFFF"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="@id/ivPremIcon"
                    app:layout_constraintStart_toEndOf="@id/ivPremIcon"
                    app:layout_constraintTop_toBottomOf="@id/tvPremTitle" />


            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GENERAL"
                android:textColor="#60FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="10dp"/>

            <!-- СПИСОК КНОПОК -->
            <!-- Высота 72dp задана жестко, чтобы они не сплющивались -->

            <include
                android:id="@+id/btnTelegram"
                layout="@layout/item_menu_modern"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"/>

            <include
                android:id="@+id/btnRate"
                layout="@layout/item_menu_modern"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"/>

            <include
                android:id="@+id/btnShare"
                layout="@layout/item_menu_modern"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"/>

            <include
                android:id="@+id/btnAbout"
                layout="@layout/item_menu_modern"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"/>


        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>